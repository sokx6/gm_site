# ============================================================
# GM Site 环境变量覆盖示例
# 复制此文件为 backend/.env 并填入实际值
# 环境变量优先级高于 config.yaml 中的对应字段
# ============================================================
# 使用方式：
#   1. 复制为 .env 文件
#   2. 填入实际值
#   3. 运行程序时自动读取
#   4. 也可通过系统环境变量设置（系统环境变量优先级更高）

# SMTP 密码（163邮箱为授权码，非邮箱登录密码）
# 对应 config.yaml: smtp.password
GM_SMTP_PASSWORD=your-smtp-password-here

# JWT Access Token 密钥（至少 32 位随机字符）
# 对应 config.yaml: jwt.access_secret
GM_JWT_ACCESS_SECRET=your-access-secret-32chars-minimum-here

# JWT Refresh Token 密钥（至少 32 位随机字符）
# 对应 config.yaml: jwt.refresh_secret
GM_JWT_REFRESH_SECRET=your-refresh-secret-32chars-minimum-here

# 兰空图床登录密码
# 对应 config.yaml: lsky.password
GM_LSKY_PASSWORD=your-lsky-password-here
